# CLIProxyNew — секреты (только через env / k8s Secret, никогда в config.yaml).
# Копируйте как .env для локальной разработки. В k8s монтируется из Secret.

# Мастер-ключ AES-256-GCM (base64, 32 байта) для шифрования upstream-credentials (R5).
# Сгенерировать: openssl rand -base64 32
CLIPROXY_ENCRYPTION_KEY=

# Пароль service-account LDAP (R1). Не шифруется AES — только env.
LDAP_BIND_PASSWORD=

# Пароль Postgres (подставляется в DSN через $PASSWORD или pgxpassfile).
DB_PASSWORD=

# Опциональные override'ы конфига (12-factor):
# CLIPROXY_CONFIG=config.yaml          # путь к config.yaml
# CLIPROXY_SERVER_ADDR=:8080           # override server.addr
# CLIPROXY_DB_DSN=postgres://...       # override db.dsn
# CLIPROXY_LOG_LEVEL=debug             # override logging.level
