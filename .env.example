# Скопируйте в .env только для локальной оболочки; реальные значения не коммитьте.
# Полный DSN, включая пароль, переопределяет db.dsn из config.yaml.
CLIPROXY_DB_DSN=postgres://cliproxy:change-me@localhost:5432/cliproxy?sslmode=disable

# Base64 от ровно 32 байт. Для ротации используйте JSON version -> base64.
CLIPROXY_ENCRYPTION_KEY=
CLIPROXY_ENCRYPTION_PREVIOUS_KEYS=

# LDAP service-account secret.
LDAP_BIND_PASSWORD=

# Необязательная system proxy policy процесса.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Только для development/test с auth.mode=static.
CLIPROXY_STATIC_USER_USERNAME=
CLIPROXY_STATIC_USER_PASSWORD=
CLIPROXY_STATIC_USER_ROLE=admin
